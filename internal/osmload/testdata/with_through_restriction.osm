<?xml version="1.0" encoding="UTF-8"?>
<osm version="0.6">
  <!-- T-style intersection at node 1.
       The "main" road is a single 3-node through-way [2, 1, 3]:
         - node 2 is east of node 1
         - node 3 is west of node 1
       So when applyOSMRestrictions picks the from-edge for a restriction
       whose from-member is way 100 (the through-way), there are two
       candidate edges that end at node 1: the forward-direction edge
       (2 → 1, i.e. westbound, matching the way's node order) and the
       reverse-direction edge (3 → 1, eastbound). The forward edge is
       the OSM convention. -->
  <node id="1" lat="40.0000" lon="-74.0000"/>  <!-- center / via -->
  <node id="2" lat="40.0000" lon="-73.9990"/>  <!-- east end -->
  <node id="3" lat="40.0000" lon="-74.0010"/>  <!-- west end -->
  <node id="4" lat="39.9990" lon="-74.0000"/>  <!-- south end -->

  <!-- Single through-way 2 → 1 → 3 (east → center → west, westbound forward). -->
  <way id="100">
    <nd ref="2"/><nd ref="1"/><nd ref="3"/>
    <tag k="highway" v="residential"/>
  </way>
  <!-- Side road, anchored at the via node. -->
  <way id="200">
    <nd ref="1"/><nd ref="4"/>
    <tag k="highway" v="residential"/>
  </way>

  <!-- A westbound vehicle (forward direction along way 100, arriving at
       node 1 from node 2) is forbidden from turning south onto way 200.
       Westbound → southbound at this geometry = LEFT turn. -->
  <relation id="500">
    <member type="way"  ref="100" role="from"/>
    <member type="node" ref="1"   role="via"/>
    <member type="way"  ref="200" role="to"/>
    <tag k="type" v="restriction"/>
    <tag k="restriction" v="no_left_turn"/>
  </relation>
</osm>
